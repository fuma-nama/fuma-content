{
  "name": "fuma-content",
  "version": "1.2.0",
  "description": "The content processing layer for your app.",
  "keywords": [
    "Content",
    "Docs"
  ],
  "homepage": "https://fuma-content.vercel.app",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fuma-content",
  "bin": "./dist/bin.js",
  "files": [
