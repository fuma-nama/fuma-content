    "@standard-schema/spec": "^1.1.0",
    "chokidar": "^5.0.0",
    "esbuild": "^0.27.3",
    "estree-util-value-to-estree": "^3.5.0",
    "github-slugger": "^2.0.0",
    "js-yaml": "^4.1.1",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-markdown": "^2.1.2",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.3",
    "tinyexec": "^1.0.2",
    "tinyglobby": "^0.2.15",
    "unified": "^11.0.5",
    "unist-util-remove-position": "^5.0.0",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.4.0",
    "@types/picomatch": "^4.0.2",
    "@types/react": "^19.2.14",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-mdx-jsx": "^3.2.0",
    "micromark-util-types": "^2.0.2",
    "next": "16.1.6",
    "react": "^19.2.4",
    "remark": "^15.0.1",
    "remark-directive": "^4.0.0",
    "remark-mdx": "^3.1.1",
    "remark-stringify": "^11.0.0",
    "rollup": "^4.59.0",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "typescript-config": "workspace:*",
    "unplugin-vue": "^7.1.1",
    "vite": "^7.3.1",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5",
    "webpack": "^5.105.4"
  },
  "peerDependencies": {
    "@types/mdast": "*",
    "@types/mdx": "*",
    "next": "^15.3.0 || ^16.0.0",
    "react": "*",
    "vite": "6.x.x || 7.x.x",
    "vue": "3.x.x"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "@types/mdx": {
      "optional": true
    },
    "@types/mdast": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
